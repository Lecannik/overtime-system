# =======================================================
# Шаблон переменных окружения для ПРОДАКШН-сервера
# =======================================================
# Скопируйте этот файл в .env и заполните все значения:
#   cp .env.prod.example .env
#
# ⚠️ НИКОГДА не коммитьте .env с реальными данными в Git!
# =======================================================

# ──────── База данных PostgreSQL ────────
POSTGRES_USER=overtime_user
POSTGRES_PASSWORD=СГЕНЕРИРУЙТЕ_НАДЕЖНЫЙ_ПАРОЛЬ
POSTGRES_DB=overtime_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ──────── Безопасность (JWT) ────────
# Сгенерируйте: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=СГЕНЕРИРУЙТЕ_СЕКРЕТНЫЙ_КЛЮЧ
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ──────── CORS ────────
# Укажите реальный адрес вашего сервера (через запятую, если несколько).
# Примеры:
#   http://92.46.127.98
#   https://overtime.company.kz
# ⚠️ НЕ используйте * в продакшне!
ALLOWED_ORIGINS=http://92.46.127.98

# Базовый URL фронтенда для SSO редиректов
FRONTEND_BASE_URL=https://overtime.polymedia.kz

# Настройки сессионных кук (для продакшна secure=True)
COOKIE_SECURE=True
COOKIE_SAMESITE=strict

# Вывод SQL-запросов в логи (в продакшне False)
SQL_ECHO=False

# ──────── Microsoft Office 365 (OTP по email) ────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_SENDER_EMAIL=
MS_CLIENT_SECRET_ID=

# ──────── Telegram Bot ────────
TELEGRAM_BOT_TOKEN=

# ──────── Odoo CRM (опционально) ────────
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_PASSWORD=